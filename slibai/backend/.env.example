# Copy this to .env and fill in your values

# REQUIRED: PostgreSQL connection string from Supabase (or any Postgres provider).
# If this is missing, the app falls back to SQLite, which is wiped on every Render redeployment.
# Find this in your Supabase project → Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

SECRET_KEY=change-me-to-a-long-random-string

FRONTEND_URL=https://slibai.vercel.app
BACKEND_URL=https://slibai.onrender.com

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: SMTP for password reset emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
