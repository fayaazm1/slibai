# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.python-version

# Desktop build output (large binaries — don't commit these)
backend/downloads/*.dmg
backend/downloads/*.exe
backend/downloads/*.AppImage
backend/downloads/*.blockmap
backend/downloads/*.yaml
backend/downloads/mac/
backend/downloads/mac-arm64/
backend/downloads/win-unpacked/
backend/downloads/linux-unpacked/
desktop/node_modules/

# Data backups / temp files
backend/app/data/ai_tools_backup.json
backend/app/data/*.tmp

# Frontend dependencies and build output
node_modules/
frontend/node_modules/
frontend/dist/

# macOS
.DS_Store
Thumbs.db

# Environment variables (never commit secrets)
.env
.env.local

# IDE
.vscode/settings.json
.idea/

# Logs
*.log
